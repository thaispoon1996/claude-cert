generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  examDate         DateTime?
  dailyGoalMinutes Int      @default(30)
  notifyEnabled    Boolean  @default(true)
  notifyHour       Int      @default(9)

  accounts         Account[]
  sessions         Session[]
  attempts         Attempt[]
  mockExamSessions MockExamSession[]
  reviewSchedules  ReviewSchedule[]
  lessonProgress   LessonProgress[]
  labProgress      LabProgress[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Domain {
  id          String @id @default(cuid())
  number      Int    @unique
  name        String
  nameVi      String
  weight      Float
  description String?
  createdAt   DateTime @default(now())

  subdomains  Subdomain[]
}

model Subdomain {
  id         String @id @default(cuid())
  domainId   String
  number     String
  name       String
  nameVi     String
  focus      String
  concepts   String
  createdAt  DateTime @default(now())

  domain     Domain     @relation(fields: [domainId], references: [id])
  lessons    Lesson[]
  questions  Question[]
  labs       Lab[]
}

model Lesson {
  id           String @id @default(cuid())
  subdomainId  String
  title        String
  titleVi      String
  summary      String
  content      String
  diagramSvg   String?
  antiPatterns String
  order        Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subdomain    Subdomain        @relation(fields: [subdomainId], references: [id])
  quizItems    Question[]       @relation("LessonQuiz")
  progress     LessonProgress[]
}

model Question {
  id                 String @id @default(cuid())
  subdomainId        String
  lessonId           String?
  scenario           String
  stem               String
  optionA            String
  optionB            String
  optionC            String
  optionD            String
  correctAnswer      String
  explanationCorrect String
  explanationA       String
  explanationB       String
  explanationC       String
  explanationD       String
  difficulty         String
  isAntiPattern      Boolean  @default(false)
  tags               String
  isDiagnostic       Boolean  @default(false)
  createdAt          DateTime @default(now())

  subdomain       Subdomain        @relation(fields: [subdomainId], references: [id])
  lesson          Lesson?          @relation("LessonQuiz", fields: [lessonId], references: [id])
  attempts        Attempt[]
  reviewSchedules ReviewSchedule[]
}

model Attempt {
  id             String @id @default(cuid())
  userId         String
  questionId     String
  selectedAnswer String
  isCorrect      Boolean
  confidence     String
  context        String
  mockExamId     String?
  createdAt      DateTime @default(now())

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question         @relation(fields: [questionId], references: [id])
  mockExam MockExamSession? @relation(fields: [mockExamId], references: [id])
}

model MockExamSession {
  id           String   @id @default(cuid())
  userId       String
  mode         String
  domainFilter String?
  questionIds  String
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  timeSpentSec Int?
  rawScore     Int?
  scaledScore  Int?
  passed       Boolean?
  domainScores String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts Attempt[]
}

model ReviewSchedule {
  id           String   @id @default(cuid())
  userId       String
  questionId   String
  nextReviewAt DateTime
  interval     Int      @default(1)
  easeFactor   Float    @default(2.5)
  repetitions  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@unique([userId, questionId])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  status      String   @default("unread")
  quizScore   Int?
  completedAt DateTime?
  updatedAt   DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
}

model Lab {
  id             String @id @default(cuid())
  subdomainId    String
  title          String
  titleVi        String
  objective      String
  prerequisites  String
  steps          String
  expectedOutput String
  challenge      String?
  quizItems      String
  order          Int
  createdAt      DateTime @default(now())

  subdomain Subdomain   @relation(fields: [subdomainId], references: [id])
  progress  LabProgress[]
}

model LabProgress {
  id          String   @id @default(cuid())
  userId      String
  labId       String
  status      String   @default("not_started")
  quizScore   Int?
  completedAt DateTime?
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lab  Lab  @relation(fields: [labId], references: [id])

  @@unique([userId, labId])
}
